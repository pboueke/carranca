#!/usr/bin/env bash
# carranca pre-commit hook
# Runs lint + unit tests, updates README badges, blocks commit on failure.
# Setup: make hooks (or: git config core.hooksPath .githooks)
set -euo pipefail

echo "=== carranca pre-commit ==="

# Verify CHANGELOG.md exists and has a valid semver header
if [ ! -f CHANGELOG.md ]; then
  echo "ERROR: CHANGELOG.md not found"
  exit 1
fi

VERSION="$(grep -m1 '## \[' CHANGELOG.md | sed 's/.*\[\(.*\)\].*/\1/')"
if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "ERROR: CHANGELOG.md first version header is not valid semver: '$VERSION'"
  echo "Expected format: ## [X.Y.Z] - YYYY-MM-DD"
  exit 1
fi

echo "Version: $VERSION"

# Run lint + unit tests (generates tests/.results.json)
make check

# Update README badges from test results
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
bash "$HOOK_DIR/update-badges.sh"

# Stage README.md if badges changed
if ! git diff --quiet README.md 2>/dev/null; then
  git add README.md
  echo "pre-commit: staged updated README.md badges"
fi

echo "=== pre-commit passed ==="
