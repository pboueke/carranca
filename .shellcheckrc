# ShellCheck configuration for carranca
# https://www.shellcheck.net/wiki/

# Default shell dialect
shell=bash

# Disable specific checks:
# SC1091: Not following sourced files (can't resolve dynamic paths)
# SC2034: Variable appears unused (false positives with sourced libs)
# SC2012: Use find instead of ls (our filenames are hex IDs, safe)
# SC2119: Use func "$@" if function's $1 should mean script's $1 (false positive in tests)
disable=SC1091,SC2034,SC2012,SC2119
