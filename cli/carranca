#!/usr/bin/env bash
# carranca — containerized agent runtime with session logging
set -euo pipefail

# Resolve install dir from the real path of this script (follows symlinks)
CARRANCA_HOME="${CARRANCA_HOME:-$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)}"
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  init)
    source "$CARRANCA_HOME/cli/init.sh" "$@"
    ;;
  config)
    source "$CARRANCA_HOME/cli/config.sh" "$@"
    ;;
  log)
    source "$CARRANCA_HOME/cli/log.sh" "$@"
    ;;
  kill)
    source "$CARRANCA_HOME/cli/kill.sh" "$@"
    ;;
  status)
    source "$CARRANCA_HOME/cli/status.sh" "$@"
    ;;
  run)
    source "$CARRANCA_HOME/cli/run.sh" "$@"
    ;;
  diff)
    source "$CARRANCA_HOME/cli/diff.sh" "$@"
    ;;
  help|-h|--help)
    case "${1:-}" in
      init) source "$CARRANCA_HOME/cli/init.sh" help ;;
      config) source "$CARRANCA_HOME/cli/config.sh" help ;;
      log) source "$CARRANCA_HOME/cli/log.sh" help ;;
      kill) source "$CARRANCA_HOME/cli/kill.sh" help ;;
      status) source "$CARRANCA_HOME/cli/status.sh" help ;;
      run) source "$CARRANCA_HOME/cli/run.sh" help ;;
      diff) source "$CARRANCA_HOME/cli/diff.sh" help ;;
      "")
        echo "carranca — containerized agent runtime with session logging"
        echo ""
        echo "Usage: carranca <command>"
        echo "       carranca help <command>"
        echo ""
        echo "Commands:"
        echo "  config  Propose carranca config updates for the current workspace"
        echo "  diff    Compare two session logs"
        echo "  init    Scaffold carranca config in the current directory"
        echo "  kill    Stop one session or all active sessions"
        echo "  log     Pretty-print the latest or selected session log"
        echo "  run     Start an agent session in a containerized runtime"
        echo "  status  Show active sessions and recent session logs for the current repo"
        echo "  help    Show this help message"
        echo ""
        echo "Run 'carranca help <command>' for command-specific help."
        echo ""
        echo "Config:  ~/.config/carranca/config.yml"
        echo "State:   ~/.local/state/carranca/"
        echo "Install: ~/.local/share/carranca/"
        ;;
      *)
        echo "carranca: unknown command '$1'" >&2
        echo "Run 'carranca help' for usage." >&2
        exit 1
        ;;
    esac
    ;;
  *)
    echo "carranca: unknown command '$COMMAND'" >&2
    echo "Run 'carranca help' for usage." >&2
    exit 1
    ;;
esac
